# ============================================
# CrewAI Stock - 环境变量配置模板
# ============================================
# 说明: 复制此文件为 .env 并填写真实的 API 密钥
#       cp .env.example .env

# === DeepSeek LLM (必需) ===
# 官网: https://platform.deepseek.com
# 注册即送 500 万 tokens
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === 硅基流动 Embeddings (推荐，用于 CrewAI Memory) ===
# 官网: https://cloud.siliconflow.cn
# 注册即送 2000 万 tokens
SILICONFLOW_API_KEY=sk-your_siliconflow_api_key_here
# 推荐模型: BAAI/bge-m3 (中英文通用，8192 tokens)
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# === 智兔 API (必需，股票数据主力源) ===
# 官网: https://api.zhituapi.cn
# 包年版 3000 次/分钟
ZHITU_API_BASE_URL=https://api.zhituapi.cn
ZHITU_API_TOKEN=your_zhitu_api_token_here

# === Grok API (用于实时新闻 / 社区情绪搜索) ===
# 官网: https://x.ai
GROK_API_KEY=your_grok_api_key_here
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-beta

# === Tavily 新闻 API (备用) ===
# 官网: https://www.tavily.com/
TAVILY_API_KEY=tvly-your_tavily_api_key_here
TAVILY_BASE_URL=https://api.tavily.com

# 多Key轮询模式（可选）- 配置多个 Key 自动轮询，突破单 Key 限制
# TAVILY_API_KEY_1=tvly-your_first_key_here
# TAVILY_API_KEY_2=tvly-your_second_key_here
# TAVILY_API_KEY_3=tvly-your_third_key_here

# === PushPlus 微信推送 (可选) ===
# 官网: https://www.pushplus.plus/
PUSHPLUS_TOKEN=your_pushplus_token_here
PUSHPLUS_CHANNEL=wechat

# === 微信公众号推送 (可选，与 PushPlus 二选一) ===
# WECHAT_APPID=your_wechat_appid_here
# WECHAT_SECRET=your_wechat_secret_here
# WECHAT_TEMPLATE_ID=your_template_id_here
# WECHAT_OPENID=your_openid_here

# 推送渠道选择: pushplus / wechat
NOTIFICATION_CHANNEL=pushplus

# === Stock MCP 服务 (可选) ===
STOCK_MCP_URL=https://stock.doiiars.com/mcp
STOCK_MCP_ENABLED=true
STOCK_MCP_RESPONSE_FORMAT=toon
STOCK_MCP_CONNECT_TIMEOUT=30

# === 社区情绪配置 ===
COMMUNITY_CACHE_TTL=3600
COMMUNITY_REQUEST_DELAY=1.5

# === 系统配置 (Agent 参考值，非强制) ===
INITIAL_CAPITAL=100000
TARGET_MONTHLY_RETURN=50
STOP_LOSS_PCT=8
STOP_PROFIT_PCT=20
MAX_POSITION_PCT=40

# === 数据库 ===
DATABASE_PATH=data/stock_trading.db

# === 日志配置 ===
LOG_LEVEL=INFO
LOG_FILE=logs/crewai_stock.log

# === Flask Web ===
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_PORT=5000
# Flask Session 密钥（建议自动生成，留空则启动时随机生成）
FLASK_SECRET_KEY=

# === 其他 ===
TIMEZONE=Asia/Shanghai
ENABLE_CACHE=1
CACHE_TTL=60
